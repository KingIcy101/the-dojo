# Copy this to .env and fill in real values
# NEVER commit .env — it's in .gitignore

# Twilio (voice calls + SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+17038225792

# Deepgram (speech-to-text)
DEEPGRAM_API_KEY=your_deepgram_key_here

# Anthropic (Claude — brain)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Cartesia (text-to-speech)
CARTESIA_API_KEY=your_cartesia_key_here
CARTESIA_VOICE_ID=a38e4e85-e815-43ab-acf1-907c4688dd6c

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=8465598242

# Notion integration
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000
TUNNEL_URL=https://your-ngrok-or-tunnel-url.ngrok.io
